PORT=5000

# Replace <username>, <password>, <cluster>, and <AppName> with your MongoDB Atlas credentials.
# Find these in MongoDB Atlas > Database Access and your cluster's connection string.
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>"

CLIENT_ORIGIN=http://localhost:5173

# Generate a secure random secret, e.g.:
#   openssl rand -base64 32
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="<your-strong-random-jwt-secret>"
